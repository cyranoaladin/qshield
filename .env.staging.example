# QuantaLayer staging environment template.
# Replace placeholders in the deployment secret store. Do not commit real secrets.

NODE_ENV=production
API_PORT=3001
API_CORS_ORIGIN=https://staging.quantalayer.app
NEXT_PUBLIC_API_URL=https://api-staging.quantalayer.app

DATABASE_URL=postgresql://quantalayer:<password>@<postgres-host>:5432/quantalayer
REDIS_URL=redis://<redis-host>:6379

HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
SOLANA_CLUSTER=mainnet-beta
JUPITER_PRICE_URL=https://api.jup.ag/price/v2

SCAN_CACHE_TTL_SECONDS=3600
RATE_LIMIT_SCANS_PER_MINUTE=10
LOG_LEVEL=info
SENTRY_DSN=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

API_URL=https://api-staging.quantalayer.app
STAGING_URL=https://api-staging.quantalayer.app
SMOKE_SOLANA_ADDRESS=
SMOKE_WAITLIST_EMAIL=smoke+staging@quantalayer.app
SMOKE_API_WRITE=false
SMOKE_STAGING_WRITE=false

{
  "name": "qshield",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter @qshield/web --filter @qshield/api dev",
    "lint": "prettier --check . && eslint .",
    "typecheck": "pnpm -r --parallel typecheck",
    "test": "pnpm -r --parallel test",
    "test:coverage": "pnpm -r --parallel test:coverage",
    "build": "pnpm -r --parallel build"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@next/eslint-plugin-next": "15.5.20",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "prettier": "3.9.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  }
}

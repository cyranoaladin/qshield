{
  "name": "@qshield/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --conditions=development watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@qshield/shared": "workspace:*",
    "dotenv": "17.2.3",
    "fastify": "5.9.0"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "tsx": "4.23.0"
  }
}

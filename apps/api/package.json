{
  "name": "@qshield/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @qshield/shared build && tsx watch src/index.ts",
    "build": "pnpm --filter @qshield/shared build && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "pnpm --filter @qshield/shared build && tsc --noEmit -p tsconfig.json",
    "test": "pnpm --filter @qshield/shared build && vitest run",
    "test:coverage": "pnpm --filter @qshield/shared build && vitest run --coverage"
  },
  "dependencies": {
    "@qshield/shared": "workspace:*",
    "dotenv": "17.2.3",
    "fastify": "5.9.0"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "tsx": "4.23.0"
  }
}

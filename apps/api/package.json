{
  "name": "@quantalayer/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --conditions=development watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.19.0",
    "@quantalayer/scoring": "workspace:*",
    "@quantalayer/shared": "workspace:*",
    "@quantalayer/solana": "workspace:*",
    "dotenv": "17.2.3",
    "fastify": "5.9.0",
    "ioredis": "5.11.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "prisma": "6.19.0",
    "tsx": "4.23.0"
  }
}

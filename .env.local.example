# QuantaLayer local staging-like environment.
# Copy to .env.local or export variables in your shell. Do not commit real secrets.

NODE_ENV=development
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

DATABASE_URL=postgresql://quantalayer:quantalayer@localhost:55432/quantalayer
REDIS_URL=redis://localhost:56379

HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
SOLANA_CLUSTER=mainnet-beta
JUPITER_PRICE_URL=https://api.jup.ag/price/v2

SCAN_CACHE_TTL_SECONDS=3600
RATE_LIMIT_SCANS_PER_MINUTE=10
LOG_LEVEL=info
SENTRY_DSN=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

API_URL=http://localhost:3001
STAGING_URL=
SMOKE_SOLANA_ADDRESS=
SMOKE_WAITLIST_EMAIL=smoke+local@quantalayer.app
SMOKE_API_WRITE=false
SMOKE_STAGING_WRITE=false

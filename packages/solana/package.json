{
  "name": "@quantalayer/solana",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "demo:scan": "tsx src/demo-scan.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@quantalayer/scoring": "workspace:*",
    "@quantalayer/shared": "workspace:*",
    "@solana/web3.js": "1.98.4",
    "bs58": "6.0.0",
    "ioredis": "5.11.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "tsx": "4.23.0"
  }
}

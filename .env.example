# QuantaLayer — environment template. Copy to .env — NEVER commit .env.
# All variables are validated at boot by packages/shared/env.ts (fail-closed).

# Shared by server and web validation.
NODE_ENV=development

# --- Server env: API ---
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000

# --- Server env: Solana / data providers ---
# Required in production. In development, API boot may continue without it,
# but real scan attempts must fail until the key is configured.
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
# mainnet-beta | devnet
SOLANA_CLUSTER=mainnet-beta
JUPITER_PRICE_URL=https://api.jup.ag/price/v2

# --- Server env: storage ---
DATABASE_URL=postgresql://quantalayer:quantalayer@localhost:5432/quantalayer
REDIS_URL=redis://localhost:6379

# --- Server env: cache / limits ---
SCAN_CACHE_TTL_SECONDS=3600
RATE_LIMIT_SCANS_PER_MINUTE=10

# --- Server env: observability ---
# Optional in development; enables Sentry when set.
SENTRY_DSN=
LOG_LEVEL=info

# --- Web env ---
NEXT_PUBLIC_API_URL=http://localhost:3001
# Optional in development; enables Plausible when set.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
